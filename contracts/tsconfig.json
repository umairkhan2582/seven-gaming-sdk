{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist"
  },
  "include": [
    "hardhat.config.ts",
    "contracts/**/*.ts",
    "deploy/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": ["node_modules"]
}